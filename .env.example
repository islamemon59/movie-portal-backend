# ===================================
# DATABASE CONFIGURATION
# ===================================
# Update with your PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/movie_portal"

# ===================================
# SERVER CONFIGURATION
# ===================================
PORT=3000
NODE_ENV="development"

# ===================================
# BETTER AUTH CONFIGURATION
# ===================================
# Generate a secure secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-here-change-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# ===================================
# CORS CONFIGURATION
# ===================================
CORS_ORIGIN="http://localhost:3000"

# ===================================
# STRIPE PAYMENT CONFIGURATION
# ===================================
# Get from https://dashboard.stripe.com/
STRIPE_API_KEY="sk_test_your_test_key_here"
STRIPE_WEBHOOK_SECRET="whsec_test_your_webhook_secret_here"

# Stripe Price IDs for subscription plans
# Create prices in Stripe Dashboard and paste their IDs
STRIPE_MONTHLY_PRICE_ID="price_monthly_subscription_id"
STRIPE_YEARLY_PRICE_ID="price_yearly_subscription_id"

# ===================================
# SSLCOMMERZ PAYMENT CONFIGURATION
# (Alternative payment provider)
# ===================================
SSLC_STORE_ID="sandbox_store_id"
SSLC_STORE_PASSWORD="sandbox_store_password"
SSLC_SUCCESS_URL="http://localhost:3000/payment/success"
SSLC_FAIL_URL="http://localhost:3000/payment/fail"
SSLC_CANCEL_URL="http://localhost:3000/payment/cancel"
SSLC_IPN_URL="http://localhost:3000/api/v1/payments/sslcommerz/ipn"
